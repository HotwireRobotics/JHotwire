{
	"control_mode": "voice",
	"command_cooldown_seconds": 2.0,
	"execution": {
		"text_mode_separate_console": true,
		"voice_mode_separate_console": false,
		"gradle_always_separate_console": true,
		"gradle_force_workspace_root": true,
		"watch_heartbeat_seconds": 30,
		"keep_separate_console_open": true
	},
	"voice": {
		"wakeword_strategy": "hey_jarvis",
		"wakeword_name": "hey_jarvis",
		"wakeword_model_path": null,
		"wakeword_threshold": 0.55,
		"wakeword_score_window_chunks": 16,
		"wakeword_inference_framework": "onnx",
		"sample_rate_hz": 16000,
		"chunk_size": 1280,
		"post_wake_record_seconds": 4.0,
		"loop_sleep_seconds": 0.0,
		"whisper_model": "base",
		"whisper_device": "cpu",
		"whisper_download_root": null,
		"input_device": null,
		"mic_gain": 4.0
	},
	"commands": [
		{
			"name": "launch simulation",
			"phrases": [
				"launch simulation",
				"run simulation",
				"start simulation"
			],
			"command": [
				"powershell",
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"helix/scripts/run_wpilib_sim_ds.ps1"
			],
			"working_directory": "."
		},
		{
			"name": "deploy code",
			"phrases": [
				"deploy code",
				"deploy robot code",
				"deploy to robot"
			],
			"command": [
				"powershell",
				"-NoProfile",
				"-Command",
				"./gradlew.bat deploy"
			],
			"working_directory": "."
		},
		{
			"name": "build code",
			"phrases": [
				"build code",
				"compile robot code"
			],
			"command": [
				"powershell",
				"-NoProfile",
				"-Command",
				"./gradlew.bat build"
			],
			"working_directory": "."
		}
	],
	"systems_check": {
		"verification_mode": "both",
		"web_host": "127.0.0.1",
		"web_port": 8765,
		"nt_server": "127.0.0.1",
		"steps": [
			{
				"id": "drive-enable",
				"title": "Drive Enable Check",
				"instructions": "Enable robot in safe test area and verify drivetrain responds to joystick input.",
				"command": [
					"powershell",
					"-NoProfile",
					"-ExecutionPolicy",
					"Bypass",
					"-File",
					"helix/scripts/run_wpilib_sim_ds.ps1"
				],
				"working_directory": ".",
				"networktables_action": {
					"action": "get",
					"table": "SmartDashboard",
					"key": "robot-pose"
				},
				"expected_observation": "Robot responds smoothly and pose updates are visible.",
				"safety_notes": "Keep wheels clear of people before enabling."
			},
			{
				"id": "deploy-ready",
				"title": "Deploy Pipeline Check",
				"instructions": "Run build and verify deploy command can start without immediate configuration errors.",
				"command": [
					"powershell",
					"-NoProfile",
					"-Command",
					"./gradlew.bat build"
				],
				"working_directory": ".",
				"expected_observation": "Build exits successfully and no critical errors appear.",
				"safety_notes": "Do not deploy to a live robot unless the pit lead approves."
			}
		]
	}
}

